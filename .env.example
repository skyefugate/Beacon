# Beacon Configuration
BEACON_HOST=0.0.0.0
BEACON_PORT=8000
BEACON_LOG_LEVEL=info

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=beacon-dev-token
INFLUXDB_ORG=beacon
INFLUXDB_BUCKET=beacon

# Collector Sidecar
COLLECTOR_URL=http://beacon-collector:9100

# Data paths (use absolute paths for Docker, relative for local dev)
BEACON_DATA_DIR=./data
BEACON_ARTIFACT_DIR=./data/artifacts
BEACON_EVIDENCE_DIR=./data/evidence
